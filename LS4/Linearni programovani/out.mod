
# mnoziny
set I := 0.. 49 ;
set J := 0.. 49 ;

# promenne
var V{I,J}, >= 0, <= 1, integer;
var P{J}, >= 0, <= 1, integer;

# podminky
s.t. a{i in I}: sum{j in J} V[i,j] = 1;

s.t. d_0{j in J}: V[ 0 ,j] + V[ 1 ,j] <= P[j];
s.t. c_0: V[ 0 , 1 ] = 0;
s.t. d_1{j in J}: V[ 0 ,j] + V[ 2 ,j] <= P[j];
