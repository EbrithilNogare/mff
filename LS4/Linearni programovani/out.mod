
# mnoziny
set I := 0.. 39 ;
set J := 0.. 39 ;

# promenne
var V{I,J}, >= 0, <= 1, integer;
var P{J}, >= 0, <= 1, integer;

# podminky
s.t. a{i in I}: sum{j in J} V[i,j] = 1;

s.t. c_0{j in J}: V[ 0 ,j] + V[ 1 ,j] <= P[j];
s.t. d_0: V[ 0 , 1 ] = 0;
