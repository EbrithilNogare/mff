
# mnoziny
set I := 0.. 99 ;
set J := 0.. 99 ;

# promenne
var V{I,J}, >= 0, <= 1, integer;
var P{J}, >= 0, <= 1, integer;

# podminky
s.t. a{i in I}: sum{j in J} V[i,j] = 1;
s.t. b{i in I, j in J}: P[j] >= V[i,j];

s.t. c_0{j in J}: V[ 0 ,j] + V[ 4 ,j] <= 1;
